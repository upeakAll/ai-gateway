# Environment variables for local development

# Application
APP_NAME=AI Gateway
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# API Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_gateway
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# Security
SECRET_KEY=change-me-in-production-with-secure-random-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
API_KEY_PREFIX=sk-

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_RPM=60
RATE_LIMIT_DEFAULT_TPM=100000
RATE_LIMIT_WINDOW_SECONDS=60

# Resilience
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=0.5
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60
REQUEST_TIMEOUT_SECONDS=120
STREAM_TIMEOUT_SECONDS=300

# Billing
BILLING_ENABLED=true
DEFAULT_INPUT_PRICE_PER_1K=0.001
DEFAULT_OUTPUT_PRICE_PER_1K=0.002

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console

# MCP
MCP_ENABLED=true
MCP_SSE_HEARTBEAT_INTERVAL=30

# Metrics
METRICS_ENABLED=true
METRICS_PATH=/metrics

# CORS
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
